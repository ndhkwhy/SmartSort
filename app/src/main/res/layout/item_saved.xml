<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_card_white_rounded"
    android:elevation="1dp">

    <ImageView
        android:id="@+id/ivBookmark"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/ic_save_filled"
        android:translationX="-3dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#4CAF50" />

    <FrameLayout
        android:id="@+id/iconContainerSaved"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/border_card_organik"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/ivIconSaved"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="5dp"
            android:src="@drawable/organik"
            android:contentDescription="Icon kategori"/>

    </FrameLayout>

    <LinearLayout
        android:id="@+id/textContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="40dp"
        android:orientation="vertical"
        app:layout_constraintStart_toEndOf="@id/iconContainerSaved"
        app:layout_constraintTop_toTopOf="@id/iconContainerSaved"
        app:layout_constraintBottom_toBottomOf="@id/iconContainerSaved"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvNamaSaved"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama Barang"
            android:textSize="15sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvKategoriSaved"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kategori"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#4CAF50"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>